        // Initialize Firebase with LOCAL persistence
        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
            firebase.auth().setPersistence(firebase.auth.Auth.Persistence.LOCAL)
                .catch(function(err) { console.warn('Persistence set warning:', err); });
        }
        var auth = firebase.auth();
        var db = firebase.database();

        // Investment Plans
        var PLANS = [
            { id: 1, name: 'Starter (Toyota)', price: 3000, daily: 700, total: 21000, duration: 30, img: 'https://images.unsplash.com/photo-1621007947382-bb3c3994e3fb?q=80&w=400', desc: 'Perfect for beginners. Start your investment journey with reliable daily returns.' },
            { id: 2, name: 'Bronze (Mercedes)', price: 10000, daily: 1333, total: 40000, duration: 30, img: 'https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8?q=80&w=400', desc: 'Enhanced returns with premium vehicle backing. Ideal for growing your portfolio.' },
            { id: 3, name: 'Silver (BMW)', price: 25000, daily: 2083, total: 62500, duration: 30, img: 'https://images.unsplash.com/photo-1555215695-3004980ad54e?q=80&w=400', desc: 'High-value investment with substantial daily earnings and capital protection.' },
            { id: 4, name: 'Gold (Lexus)', price: 50000, daily: 4166, total: 125000, duration: 30, img: 'https://images.unsplash.com/photo-1594052069771-469b76c8c9b9?q=80&w=400', desc: 'Premium tier investment with accelerated returns and priority support.' },
            { id: 5, name: 'Diamond (Range Rover)', price: 100000, daily: 8333, total: 250000, duration: 30, img: 'https://images.unsplash.com/photo-1506521781263-d8422e82f27a?q=80&w=400', desc: 'Elite investment class with maximum returns and exclusive benefits.' },
            { id: 6, name: 'VIP (Rolls-Royce)', price: 250000, daily: 20833, total: 625000, duration: 30, img: 'https://images.unsplash.com/photo-1631214503951-3751369ede00?q=80&w=400', desc: 'Ultimate investment experience with highest returns and VIP treatment.' }
        ];

        // Global variables
        var userData = null;
        var selectedPlan = null;
        var timerIntervals = {};
        var pendingDeposit = null;
        var confirmCallback = null;
        var deferredPrompt = null;
        var unsubscribeTransactions = null;

        // ========================================
        // AUTHENTICATION HANDLERS
        // ========================================
        auth.onAuthStateChanged(function(user) {
            document.getElementById('loader').style.display = 'none';
            if (user) {
                document.getElementById('auth-section').classList.add('hidden');
                document.getElementById('app-container').classList.remove('hidden');
                loadUserData(user.uid);
                startEarningsChecker();
                checkPWAInstallable();
            } else {
                document.getElementById('auth-section').classList.remove('hidden');
                document.getElementById('app-container').classList.add('hidden');
                // Cleanup listeners on logout
                Object.values(timerIntervals).forEach(function(interval) { clearInterval(interval); });
                timerIntervals = {};
                if (unsubscribeTransactions) { 
                    unsubscribeTransactions(); 
                    unsubscribeTransactions = null; 
                }
            }
        });

        function loadUserData(uid) {
            db.ref('users/' + uid).on('value', function(snap) {
                var data = snap.val();
                if (!data) return;
                userData = data;
                updateBalanceUI();
                updateProfileUI();
                updateActivePlansUI();
                renderPlans();
                renderTransactionHistory();
                renderNotifications();
                
                if (!data.claimBonus && !data.hasSeenWelcome) {
                    new bootstrap.Modal(document.getElementById('welcome-modal')).show();
                    db.ref('users/' + uid).update({ hasSeenWelcome: true });
                }
                
                if (data.bankAccount) {
                    document.getElementById('bind-sec').classList.add('hidden');
                    document.getElementById('wit-form').classList.remove('hidden');
                    document.getElementById('linked-bank-display').textContent = 
                        (data.bankAccount.bank || 'Bank') + ' •••• ' + ((data.bankAccount.num || '').slice(-4));
                    document.getElementById('linked-name-display').textContent = 
                        (data.bankAccount.name || '').replace(/(.{3}).*(.{3})/, '$1***$2');
                }
            });
        }

        function updateBalanceUI() {
            if (!userData) return;
            document.getElementById('home-bal').textContent = '₦' + ((userData.balance || 0).toLocaleString());
            document.getElementById('home-inv').textContent = '₦' + ((userData.totalInvested || 0).toLocaleString());
            document.getElementById('home-day').textContent = '₦' + ((userData.dailyIncome || 0).toLocaleString());
            document.getElementById('home-returns').textContent = '₦' + ((userData.totalReturns || 0).toLocaleString());
            var witBalEl = document.getElementById('wit-balance');
            if (witBalEl) witBalEl.textContent = '₦' + ((userData.balance || 0).toLocaleString());
        }

        function updateProfileUI() {
            if (!userData) return;
            document.getElementById('prof-name').textContent = userData.username || 'User';
            document.getElementById('prof-email').textContent = userData.email || '';
            document.getElementById('ref-code').textContent = userData.username || 'N/A';
            document.getElementById('stat-invested').textContent = '₦' + ((userData.totalInvested || 0).toLocaleString());
            document.getElementById('stat-earned').textContent = '₦' + ((userData.totalReturns || 0).toLocaleString());
            document.getElementById('stat-referrals').textContent = userData.totalReferrals || 0;
            document.getElementById('ref-earn').textContent = '₦' + ((userData.referralEarnings || 0).toLocaleString());
            document.getElementById('ref-active').textContent = userData.activeReferrals || 0;
            document.getElementById('edit-username').value = userData.username || '';
            document.getElementById('edit-email').value = userData.email || '';
        }

        // ========================================
        // INVESTMENT PLAN FUNCTIONS
        // ========================================
        function renderPlans() {
            var container = document.getElementById('plans-list');
            if (!container) return;
            container.innerHTML = PLANS.map(function(plan) {
                var roi = Math.round((plan.total / plan.price - 1) * 100);
                return '<div class="plan-card" onclick="showPlanDetail(' + plan.id + ')">' +
                    '<div class="plan-img" style="background-image:url(\'' + plan.img + '\')"></div>' +
                    '<div class="plan-details">' +
                        '<span class="plan-badge">' + roi + '% ROI</span>' +
                        '<h5 class="mb-1" style="font-size:16px">' + plan.name + '</h5>' +
                        '<p class="small text-gray mb-2" style="font-size:12px">' + plan.desc + '</p>' +
                        '<div class="plan-stats">' +
                            '<div class="plan-stat-item"><small>Investment</small><br><strong class="text-gold">₦' + plan.price.toLocaleString() + '</strong></div>' +
                            '<div class="plan-stat-item"><small>Daily Return</small><br><strong>₦' + plan.daily.toLocaleString() + '</strong></div>' +
                            '<div class="plan-stat-item"><small>Total Return</small><br><strong class="text-gold">₦' + plan.total.toLocaleString() + '</strong></div>' +
                            '<div class="plan-stat-item"><small>Duration</small><br><strong>' + plan.duration + ' Days</strong></div>' +
                        '</div>' +
                        '<button class="btn-gold btn-sm mt-2" style="padding:6px 12px; font-size:11px">View Details</button>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        function showPlanDetail(planId) {
            selectedPlan = PLANS.find(function(p) { return p.id === planId; });
            if (!selectedPlan) return;
            document.getElementById('plan-modal-title').textContent = 'Plan Details';
            document.getElementById('plan-modal-name').textContent = selectedPlan.name;
            document.getElementById('plan-modal-img').style.backgroundImage = 'url(\'' + selectedPlan.img + '\')';
            document.getElementById('plan-modal-price').textContent = '₦' + selectedPlan.price.toLocaleString();
            document.getElementById('plan-modal-daily').textContent = '₦' + selectedPlan.daily.toLocaleString();
            document.getElementById('plan-modal-total').textContent = '₦' + selectedPlan.total.toLocaleString();
            document.getElementById('plan-modal-desc').textContent = selectedPlan.desc;
            document.getElementById('plan-purchase-btn').onclick = function() {
                bootstrap.Modal.getInstance(document.getElementById('plan-modal')).hide();
                confirmPurchase(selectedPlan);
            };
            new bootstrap.Modal(document.getElementById('plan-modal')).show();
        }

        function confirmPurchase(plan) {
            if (!userData) return;
            if (userData.balance < plan.price) {
                showToast('Insufficient balance. Please deposit funds first.', 'error');
                openDepositPage();
                return;
            }
            if (!confirm('Confirm purchase of ' + plan.name + ' for ₦' + plan.price.toLocaleString() + '?\n\nDaily return: ₦' + plan.daily.toLocaleString() + '\nDuration: ' + plan.duration + ' days')) return;
            
            Promise.resolve().then(function() {
                var now = Date.now();
                var planKey = 'plan_' + now;
                var uid = auth.currentUser ? auth.currentUser.uid : null;
                if (!uid) throw new Error('User not authenticated');
                
                var updates = {};
                updates['users/' + uid + '/balance'] = (userData.balance || 0) - plan.price;
                updates['users/' + uid + '/totalInvested'] = (userData.totalInvested || 0) + plan.price;
                updates['users/' + uid + '/dailyIncome'] = (userData.dailyIncome || 0) + plan.daily;
                updates['users/' + uid + '/activePlans/' + planKey] = {
                    id: plan.id, name: plan.name, price: plan.price, daily: plan.daily,
                    total: plan.total, duration: plan.duration, startTime: now,
                    lastClaim: now, daysClaimed: 0, nextClaim: now + 86400000, status: 'active'
                };
                var txRef = db.ref('transactions').push().key;
                updates['transactions/' + txRef] = {
                    uid: uid, type: 'investment', amount: plan.price, planName: plan.name,
                    status: 'completed', timestamp: now, description: 'Activated ' + plan.name + ' plan'
                };
                
                return db.ref().update(updates);
            }).then(function() {
                // Referral commission (20%) - NON-BLOCKING
                try {
                    var referrerCode = userData.referredBy;
                    if (referrerCode && referrerCode !== 'none') {
                        db.ref('users').orderByChild('username').equalTo(referrerCode).once('value').then(function(referrerSnap) {
                            referrerSnap.forEach(function(referrer) {
                                var rData = referrer.val();
                                var commission = Math.round(plan.price * 0.20);
                                db.ref('users/' + referrer.key + '/balance').set((rData.balance || 0) + commission);
                                db.ref('users/' + referrer.key + '/referralEarnings').set((rData.referralEarnings || 0) + commission);
                                db.ref('users/' + referrer.key + '/activeReferrals').set((rData.activeReferrals || 0) + 1);
                                db.ref('transactions').push().set({
                                    uid: referrer.key, type: 'referral', amount: commission, referredUser: userData.username,
                                    source: 'investment', status: 'completed', timestamp: Date.now(),
                                    description: '20% commission from ' + userData.username + '\'s ' + plan.name + ' investment'
                                });
                            });
                        });
                    }
                } catch (refErr) { console.warn('Referral commission warning:', refErr); }
                
                showToast('✅ ' + plan.name + ' activated! Daily returns start in 24 hours.', 'success');
                navigate('home');
            }).catch(function(error) {
                console.error('Purchase error:', error);
                showToast('Failed to activate plan. Please try again.', 'error');
            });
        }

        // ========================================
        // EARNINGS & TIMER SYSTEM
        // ========================================
        function startEarningsChecker() {
            setInterval(function() {
                if (!userData || !userData.activePlans) return;
                var now = Date.now();
                var totalEarnings = 0;
                var updates = {};
                var uid = auth.currentUser ? auth.currentUser.uid : null;
                if (!uid) return;
                
                for (var planKey in userData.activePlans) {
                    var plan = userData.activePlans[planKey];
                    if (plan.status !== 'active') continue;
                    if (now >= plan.nextClaim && plan.daysClaimed < plan.duration) {
                        totalEarnings += plan.daily;
                        updates['users/' + uid + '/activePlans/' + planKey + '/lastClaim'] = now;
                        updates['users/' + uid + '/activePlans/' + planKey + '/nextClaim'] = now + 86400000;
                        updates['users/' + uid + '/activePlans/' + planKey + '/daysClaimed'] = plan.daysClaimed + 1;
                        if (plan.daysClaimed + 1 >= plan.duration) updates['users/' + uid + '/activePlans/' + planKey + '/status'] = 'completed';
                    }
                }
                
                if (totalEarnings > 0) {
                    updates['users/' + uid + '/balance'] = (userData.balance || 0) + totalEarnings;
                    updates['users/' + uid + '/totalReturns'] = (userData.totalReturns || 0) + totalEarnings;
                    var txRef = db.ref('transactions').push().key;
                    updates['transactions/' + txRef] = { uid: uid, type: 'earnings', amount: totalEarnings, status: 'completed', timestamp: now, description: 'Daily returns from active plans' };
                    db.ref().update(updates).then(function() {
                        showToast('🎉 ₦' + totalEarnings.toLocaleString() + ' daily returns credited!', 'success');
                    }).catch(function(e) { console.warn('Earnings update warning:', e); });
                }
            }, 60000);
            checkAndClaimEarnings();
        }

        function checkAndClaimEarnings() {
            if (!userData || !userData.activePlans) return;
            var now = Date.now();
            var totalEarnings = 0;
            var updates = {};
            var uid = auth.currentUser ? auth.currentUser.uid : null;
            if (!uid) return;
            for (var planKey in userData.activePlans) {
                var plan = userData.activePlans[planKey];
                if (plan.status !== 'active') continue;
                if (now >= plan.nextClaim && plan.daysClaimed < plan.duration) {
                    totalEarnings += plan.daily;
                    updates['users/' + uid + '/activePlans/' + planKey + '/lastClaim'] = now;
                    updates['users/' + uid + '/activePlans/' + planKey + '/nextClaim'] = now + 86400000;
                    updates['users/' + uid + '/activePlans/' + planKey + '/daysClaimed'] = plan.daysClaimed + 1;
                    if (plan.daysClaimed + 1 >= plan.duration) updates['users/' + uid + '/activePlans/' + planKey + '/status'] = 'completed';
                }
            }
            if (totalEarnings > 0) {
                updates['users/' + uid + '/balance'] = (userData.balance || 0) + totalEarnings;
                updates['users/' + uid + '/totalReturns'] = (userData.totalReturns || 0) + totalEarnings;
                var txRef = db.ref('transactions').push().key;
                updates['transactions/' + txRef] = { uid: uid, type: 'earnings', amount: totalEarnings, status: 'completed', timestamp: now, description: 'Daily returns from active plans' };
                db.ref().update(updates).catch(function(e) { console.warn('Initial earnings warning:', e); });
            }
        }

        function updateActivePlansUI() {
            var container = document.getElementById('active-plans-container');
            if (!container || !userData || !userData.activePlans) { 
                if (container) container.innerHTML = ''; 
                return; 
            }
            var activePlans = [];
            for (var key in userData.activePlans) {
                var plan = userData.activePlans[key];
                if (plan.status === 'active') activePlans.push([key, plan]);
            }
            activePlans.sort(function(a, b) { return b[1].nextClaim - a[1].nextClaim; });
            
            if (activePlans.length === 0) { container.innerHTML = ''; return; }
            document.getElementById('active-plans-count').textContent = activePlans.length + ' Plan' + (activePlans.length > 1 ? 's' : '') + ' Running';
            container.innerHTML = activePlans.map(function(item) {
                var key = item[0], plan = item[1];
                var now = Date.now();
                var timeLeft = Math.max(0, plan.nextClaim - now);
                var h = Math.floor(timeLeft / 3600000);
                var m = Math.floor((timeLeft % 3600000) / 60000);
                var s = Math.floor((timeLeft % 60000) / 1000);
                var progress = Math.min(100, (plan.daysClaimed / plan.duration) * 100);
                return '<div class="active-plan-card">' +
                    '<div class="d-flex justify-content-between align-items-start mb-2">' +
                        '<div><span class="badge bg-gold text-dark mb-2" style="font-size:11px">' + plan.name + '</span><p class="small mb-0">Daily Return: <strong class="text-gold">₦' + plan.daily.toLocaleString() + '</strong></p></div>' +
                        '<span class="badge bg-success" style="font-size:10px">Active</span>' +
                    '</div>' +
                    '<div class="text-center my-2"><small class="text-gray d-block mb-1" style="font-size:12px">Next payout in</small><div class="timer-display timer-pulse" id="timer-' + key + '">' + h.toString().padStart(2,'0') + ':' + m.toString().padStart(2,'0') + ':' + s.toString().padStart(2,'0') + '</div></div>' +
                    '<div class="mb-2">' +
                        '<div class="d-flex justify-content-between small mb-1" style="font-size:12px"><span>Progress</span><span>' + plan.daysClaimed + '/' + plan.duration + ' days</span></div>' +
                        '<div class="progress"><div class="progress-bar" role="progressbar" style="width: ' + progress + '%"></div></div>' +
                    '</div>' +
                    '<div class="d-flex justify-content-between small text-gray" style="font-size:12px"><span>Invested: ₦' + plan.price.toLocaleString() + '</span><span>Earned: ₦' + (plan.daily * plan.daysClaimed).toLocaleString() + '</span></div>' +
                '</div>';
            }).join('');
            
            activePlans.forEach(function(item) {
                var key = item[0], plan = item[1];
                if (timerIntervals[key]) clearInterval(timerIntervals[key]);
                timerIntervals[key] = setInterval(function() {
                    var el = document.getElementById('timer-' + key);
                    if (!el) return;
                    var tl = Math.max(0, plan.nextClaim - Date.now());
                    el.textContent = Math.floor(tl/3600000).toString().padStart(2,'0') + ':' + Math.floor((tl%3600000)/60000).toString().padStart(2,'0') + ':' + Math.floor((tl%60000)/1000).toString().padStart(2,'0');
                }, 1000);
            });
        }

        // ========================================
        // DEPOSIT FLOW
        // ========================================
        function openDepositPage() { showDepositAmountPage(); }
        function showDepositAmountPage() {
            document.querySelectorAll('section[id$="-sec"]').forEach(function(sec) { sec.classList.add('hidden'); });
            document.getElementById('deposit-amount-sec').classList.remove('hidden');
            document.getElementById('rec-amt').value = '3000';
            document.getElementById('rec-sender').value = '';
            document.getElementById('rec-ref').value = '';
            document.getElementById('deposit-amount-display').textContent = '3,000';
            document.querySelectorAll('.quick-amount-btn').forEach(function(btn) { btn.classList.remove('active'); });
            var btn = document.querySelector('.quick-amount-btn[onclick="setAmount(3000, this)"]');
            if (btn) btn.classList.add('active');
        }
        function setAmount(amount, btn) {
            document.getElementById('rec-amt').value = amount;
            document.getElementById('deposit-amount-display').textContent = amount.toLocaleString();
            document.querySelectorAll('.quick-amount-btn').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
        }
        function proceedToBankDetails() {
            var amount = parseFloat(document.getElementById('rec-amt').value);
            if (!amount || amount < 3000) { showToast('Minimum deposit amount is ₦3,000', 'error'); return; }
            pendingDeposit = { amount: amount };
            document.querySelectorAll('section[id$="-sec"]').forEach(function(sec) { sec.classList.add('hidden'); });
            document.getElementById('bank-details-sec').classList.remove('hidden');
        }
        function confirmDepositPayment() {
            var senderName = document.getElementById('rec-sender').value.trim();
            var ref = document.getElementById('rec-ref').value.trim();
            var amount = pendingDeposit ? pendingDeposit.amount : parseFloat(document.getElementById('rec-amt').value);
            if (!senderName) { showToast('Please enter your bank account name for verification', 'error'); return; }
            Promise.resolve().then(function() {
                var depositData = {
                    uid: auth.currentUser.uid, username: userData.username, amount: amount,
                    senderName: senderName, reference: ref || 'TXN' + Date.now(), status: 'pending',
                    timestamp: Date.now(), bank: 'Moniepoint MFB', accountNumber: '6930069738'
                };
                return db.ref('deposits').push().set(depositData);
            }).then(function() {
                showConfirmModal('success', 'Deposit Submitted!', 'You have successfully made a deposit of ₦' + amount.toLocaleString() + '.<br><br>Wait for confirmation within 5 minutes. Once admin approves, it will appear in your transaction history.', 'Got it', function() { navigate('home'); pendingDeposit = null; });
            }).catch(function(error) { 
                console.error('Deposit error:', error); 
                showToast('Failed to submit deposit. Please try again.', 'error'); 
            });
        }

   // ========================================
// WITHDRAWAL FUNCTIONS - FULLY DECOUPLED & ERROR-ISOLATED
// ========================================

/**
 * Opens withdrawal page
 */
function openWithdrawPage() { 
    navigate('withdraw'); 
    var amtInput = document.getElementById('wit-amt');
    if (amtInput) amtInput.value = '5000'; 
}

/**
 * Saves bank details
 */
function saveBankDetails() {
    var currentUser = firebase.auth().currentUser;
    if (!currentUser) return showToast('Please log in', 'error');

    var bank = document.getElementById('wit-bank').value.trim();
    var accountNum = document.getElementById('wit-num').value.trim();
    var accountName = document.getElementById('wit-name').value.trim();

    if (!/^\d{10}$/.test(accountNum)) return showToast('Enter a valid 10-digit account number', 'error');
    if (!accountName || accountName.length < 3) return showToast('Enter a valid account name (min 3 chars)', 'error');
    if (!bank) return showToast('Please select a bank', 'error');

    db.ref('users/' + currentUser.uid + '/bankAccount').set({ 
        bank, num: accountNum, name: accountName, updatedAt: Date.now() 
    }).then(function() {
        showToast('✅ Bank details saved!', 'success');
        document.getElementById('bind-sec')?.classList.add('hidden');
        document.getElementById('wit-form')?.classList.remove('hidden');
        document.getElementById('linked-bank-display').textContent = bank + ' •••• ' + accountNum.slice(-4);
        document.getElementById('linked-name-display').textContent = accountName.replace(/(.{3}).*(.{3})/, '$1***$2');
    }).catch(function(err) {
        console.error('Save bank error:', err);
        showToast('Failed to save bank details.', 'error');
    });
}

/**
 * MAIN WITHDRAWAL TRIGGER
 */
function submitWithdrawal() {
    var currentUser = firebase.auth().currentUser;
    var amountInput = document.getElementById('wit-amt');
    var amount = amountInput ? parseFloat(amountInput.value) : 0;
    if (!currentUser) return showToast('Please log in', 'error');
    if (!userData) return showToast('Loading user data...', 'info');
    if (isNaN(amount) || amount <= 0) return showToast('Enter a valid amount', 'error');
    if (amount < 500) return showToast('Minimum withdrawal is 500', 'info');
    if (userData.balance == null || userData.balance < amount) return showToast('Insufficient funds', 'info');
    if (!userData.bankAccount?.num) return showToast('Add bank details first', 'info');

    var submitBtn = document.querySelector('button[onclick="submitWithdrawal()"]');
    if (submitBtn) submitBtn.disabled = true;
    showToast('Processing withdrawal...', 'info');

    processWithdrawalRecords(currentUser, amount, function() {
        if (submitBtn) submitBtn.disabled = false;
    });
}

/**
 * WITHDRAWAL CORE (100% Independent of Referral)
 */
function processWithdrawalRecords(currentUser, amount, callback) {
    var witRef = db.ref('withdrawals').push();
    var txRef = db.ref('transactions').push();
    var bankInfo = userData.bankAccount || {};
    
    var withdrawalData = {
        uid: currentUser.uid, username: userData.username || 'Unknown', amount,
        bank: bankInfo.bank || '', accountNum: bankInfo.num || '', accountName: bankInfo.name || '',
        status: 'pending', requestedAt: Date.now()
    };

    var transactionData = {
        uid: currentUser.uid, type: 'withdrawal', amount, status: 'pending',
        timestamp: Date.now(),
        description: 'Withdrawal to ' + (bankInfo.bank || 'Bank') + ' (•••• ' + (bankInfo.num || '').slice(-4) + ')',
        withdrawalId: witRef.key
    };

    var userRef = db.ref('users/' + currentUser.uid);

    // ATOMIC BALANCE DEDUCTION
    userRef.transaction(function(user) {
        if (!user) return null;
        if ((user.balance || 0) < amount) return null; // Abort if insufficient
        user.balance = (user.balance || 0) - amount;
        user.lastWithdrawal = Date.now();
        return user;
    }, function(error, committed) {
        if (error || !committed) {
            showToast('Withdrawal failed. Check balance & try again.', 'error');
            if (callback) callback();            return;
        }

        // ✅ ONLY WRITES RECORDS AFTER SUCCESSFUL DEDUCTION
        var updates = {};
        updates['/withdrawals/' + witRef.key] = withdrawalData;
        updates['/transactions/' + txRef.key] = transactionData;

        db.ref().update(updates).then(function() {
            showToast('✅ Withdrawal request received!', 'success');
            if (document.getElementById('wit-amt')) document.getElementById('wit-amt').value = '';
            if (typeof updateBalanceUI === "function") updateBalanceUI();
            
            setTimeout(() => {
                navigate('wallet');
                if (callback) callback();
            }, 800);

            // 🔥 COMPLETELY SEPARATED REFERRAL CALL
            // Runs async, isolated, zero impact on withdrawal flow
            setTimeout(() => triggerReferralBonus(amount), 0);

        }).catch(function(err) {
            console.error('Record write failed:', err);
            showToast('⚠️ Request saved partially. Contact support.', 'error');
            if (callback) callback();
        });
    }, false); // Boolean false, NOT object
}

// ========================================
// 🔥 REFERRAL SYSTEM (100% INDEPENDENT)
// No forEach. No UI impact. Error-isolated.
// ========================================
function triggerReferralBonus(amount) {
    // Wrap in try/catch + promise catch to guarantee zero crashes
    try {
        var refCode = (userData?.referredBy || '').trim();
        if (!refCode || refCode === 'none') return;

        db.ref('users').orderByChild('username').equalTo(refCode).limitToFirst(1).once('value')
            .then(function(snap) {
                // ✅ Safe guards: NO forEach, NO undefined access
                if (!snap.exists()) return;
                
                var data = snap.val();
                if (!data) return;
                
                var keys = Object.keys(data);
                if (!keys || keys.length === 0) return;                
                var refUid = keys[0];
                var bonus = Math.round(amount * 0.20);
                if (bonus <= 0) return;

                // Update referrer balance
                return db.ref('users/' + refUid).transaction(function(u) {
                    if (!u) return null;
                    u.balance = (u.balance || 0) + bonus;
                    u.referralEarnings = (u.referralEarnings || 0) + bonus;
                    return u;
                }).then(function(res) {
                    if (!res.committed) return;
                    
                    // Log bonus (fire-and-forget)
                    return db.ref('transactions').push().set({
                        uid: refUid, type: 'referral', amount: bonus, status: 'completed',
                        timestamp: Date.now(),
                        description: 'Referral bonus from ' + (userData?.username || 'User')
                    }).catch(function() { /* Silent fail for log */ });
                });
            })
            .catch(function(err) {
                // 🛡️ COMPLETELY SILENT. Never shows to user.
                console.warn('[Referral] Bonus skipped (non-critical):', err.message);
            });
    } catch (e) {
        console.error('[Referral] Unexpected error:', e);
    }
}

        // ========================================
        // ✅ WALLET TAB FIX - Transaction History
        // ========================================
        function renderTransactionHistory() {
            var container = document.getElementById('tx-list');
            if (!container) return;
            
            // Detach old listener if exists
            if (unsubscribeTransactions) { 
                unsubscribeTransactions(); 
                unsubscribeTransactions = null; 
            }
            
            // Get current user UID safely
            var currentUser = auth.currentUser;
            if (!currentUser) {
                container.innerHTML = '<div class="empty-state"><i class="bi bi-clock-history"></i><p>Please login to view history</p></div>';
                return;
            }
            var uid = currentUser.uid;

            // Real-time listener for transactions with error handling
            unsubscribeTransactions = db.ref('transactions')
                .orderByChild('uid')
                .equalTo(uid)
                .limitToLast(50)
                .on('value', function(snap) {
                    var txs = [];
                    snap.forEach(function(child) { 
                        txs.push({ id: child.key, ...child.val() }); 
                    });
                    
                    // Sort by timestamp descending (newest first)
                    txs.sort(function(a, b) { 
                        return (b.timestamp || 0) - (a.timestamp || 0); 
                    });
                    
                    if (txs.length === 0) {
                        container.innerHTML = '<div class="empty-state"><i class="bi bi-clock-history"></i><p>No transactions yet</p><small>Start by making a deposit or investment</small></div>';
                        return;
                    }

                    container.innerHTML = txs.map(function(tx) {
                        var date = new Date(tx.timestamp || Date.now());
                        var timeStr = date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                        var dateStr = date.toLocaleDateString();
                        
                        // Status badge logic
                        var statusClass = 'status-pending', statusText = 'Pending';
                        if (tx.status === 'approved' || tx.status === 'completed') { 
                            statusClass = 'status-approved'; 
                            statusText = 'Completed'; 
                        } else if (tx.status === 'declined') { 
                            statusClass = 'status-declined'; 
                            statusText = 'Declined'; 
                        }
                        
                        // Amount color logic
                        var amountClass = '';
                        if (['deposit', 'earnings', 'referral', 'bonus', 'balance-adjust'].indexOf(tx.type) !== -1) {
                            amountClass = 'positive';
                        } else if (['withdrawal', 'investment'].indexOf(tx.type) !== -1) {
                            amountClass = 'negative';
                        }
                        
                        // Type icon and label
                        var typeIcon = 'bi-question-circle', typeLabel = 'Unknown';
                        if (tx.type) {
                            typeLabel = tx.type.charAt(0).toUpperCase() + tx.type.slice(1);
                        }
                        switch(tx.type) {
                            case 'deposit': typeIcon = 'bi-wallet2'; typeLabel = 'Deposit'; break;
                            case 'withdrawal': typeIcon = 'bi-cash-stack'; typeLabel = 'Withdrawal'; break;
                            case 'investment': typeIcon = 'bi-gem'; typeLabel = 'Investment'; break;
                            case 'earnings': typeIcon = 'bi-graph-up'; typeLabel = 'Daily Return'; break;
                            case 'referral': typeIcon = 'bi-people'; typeLabel = 'Referral'; break;
                            case 'bonus': typeIcon = 'bi-gift'; typeLabel = 'Bonus'; break;
                            case 'balance-adjust': typeIcon = 'bi-currency-exchange'; typeLabel = 'Balance Adjust'; break;
                        }
                        
                        return '<div class="tx-item ' + (tx.type || '') + '">' +
                            '<div class="tx-header">' +
                                '<span><i class="bi ' + typeIcon + ' me-2"></i>' + typeLabel + '</span>' +
                                '<span class="tx-status ' + statusClass + '">' + statusText + '</span>' +
                            '</div>' +
                            '<div class="tx-desc">' + (tx.description || '') + '</div>' +
                            '<div class="d-flex justify-content-between align-items-center mt-2">' +
                                '<small class="tx-time">' + dateStr + ' ' + timeStr + '</small>' +
                                '<span class="tx-amount ' + amountClass + '">' +
                                    (['withdrawal', 'investment'].indexOf(tx.type) !== -1 ? '-' : '+') + '₦' + ((tx.amount || 0).toLocaleString()) +
                                '</span>' +
                            '</div>' +
                        '</div>';
                    }).join('');
                }, function(error) {
                    // Error handling for Firebase query
                    console.warn('Transaction listener error:', error);
                    container.innerHTML = '<div class="empty-state"><p>Unable to load history. Retrying...</p><small class="text-gold">Please check your connection</small></div>';
                });
        }

        // ========================================
        // NAVIGATION & UI FUNCTIONS
        // ========================================
        function navigate(section) {
            // Hide all sections first
            document.querySelectorAll('section[id$="-sec"]').forEach(function(sec) { sec.classList.add('hidden'); });
            
            // Show target section
            var target = document.getElementById(section + '-sec');
            if (target) target.classList.remove('hidden');
            
            // Update nav active state
            document.querySelectorAll('.nav-link').forEach(function(link) { link.classList.remove('active'); });
            var activeNav = document.querySelector('.nav-link[onclick="navigate(\'' + section + '\')"]');
            if (activeNav) activeNav.classList.add('active');
            
            // Refresh data when entering specific sections
            if (section === 'wallet') {
                renderTransactionHistory(); // This is the wallet tab fix!
            }
            if (section === 'invest') renderPlans();
            if (section === 'profile') updateProfileUI();
            
            // Scroll to top
            window.scrollTo(0, 0);
        }

        function toggleAuth(type) {
            document.getElementById('register-page').classList.toggle('hidden', type !== 'reg');
            document.getElementById('login-page').classList.toggle('hidden', type !== 'login');
        }

        function showToast(message, type) {
            type = type || 'info';
            var container = document.getElementById('toast-container');
            var toastId = 'toast-' + Date.now();
            var icon = 'bi-info-circle-fill';
            var toastClass = 'toast-info';
            if (type === 'success') { icon = 'bi-check-circle-fill'; toastClass = 'toast-success'; }
            else if (type === 'error') { icon = 'bi-exclamation-triangle-fill'; toastClass = 'toast-error'; }
            else if (type === 'warning') { icon = 'bi-exclamation-circle-fill'; toastClass = 'toast-warning'; }
            
            var toast = document.createElement('div');
            toast.className = 'custom-toast ' + toastClass; toast.id = toastId;
            toast.innerHTML = '<i class="toast-icon bi ' + icon + '"></i><div class="toast-message">' + message + '</div><button class="toast-close" onclick="document.getElementById(\'' + toastId + '\')?.remove()"><i class="bi bi-x"></i></button>';
            container.appendChild(toast);
            setTimeout(function() { 
                if (toast.parentNode) { 
                    toast.style.opacity = '0'; 
                    toast.style.transform = 'translateX(100%)'; 
                    setTimeout(function() { if (toast.parentNode) toast.remove(); }, 300); 
                } 
            }, 5000);
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() { 
                showToast('✅ Copied to clipboard!', 'success');
            }).catch(function() {
                var textarea = document.createElement('textarea'); 
                textarea.value = text; 
                document.body.appendChild(textarea); 
                textarea.select(); 
                document.execCommand('copy'); 
                document.body.removeChild(textarea); 
                showToast('✅ Copied!', 'success');
            });
        }

        function copyReferralLink() {
            var refCode = userData ? (userData.username || '') : '';
            var link = window.location.origin + window.location.pathname + '?ref=' + refCode;
            copyToClipboard(link);
        }

        // ========================================
        // AUTO-PASS REF CODE FROM URL
        // ========================================
        function checkUrlRefCode() {
            var urlParams = new URLSearchParams(window.location.search);
            var refCode = urlParams.get('ref');
            if (refCode) {
                var refInput = document.getElementById('reg-invite');
                if (refInput) {
                    refInput.value = refCode.toUpperCase().trim();
                    showToast('Referral code "' + refCode.toUpperCase() + '" applied!', 'info');
                }
                // Clean URL without reloading
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        }
        // Run on load
        checkUrlRefCode();

        // ========================================
        // PWA INSTALL
        // ========================================
        function checkPWAInstallable() {
            window.addEventListener('beforeinstallprompt', function(e) { 
                e.preventDefault(); 
                deferredPrompt = e; 
                var pwaBox = document.getElementById('pwa-install-box');
                if (pwaBox) pwaBox.classList.remove('hidden'); 
            });
            if (window.matchMedia('(display-mode: standalone)').matches) {
                var pwaBox = document.getElementById('pwa-install-box');
                if (pwaBox) pwaBox.classList.add('hidden');
            }
        }
        function installPWA() {
            if (!deferredPrompt) { 
                showToast('📱 To install: Tap browser menu → "Add to Home Screen"', 'info'); 
                return; 
            }
            deferredPrompt.prompt();
            deferredPrompt.userChoice.then(function() {
                deferredPrompt = null;
                var pwaBox = document.getElementById('pwa-install-box');
                if (pwaBox) pwaBox.classList.add('hidden');
                showToast('✅ App installation prompt shown!', 'success');
            });
        }

        // ========================================
        // PROFILE ACTIONS - ALL FUNCTIONING
        // ========================================
        function openEditProfile() {
            document.getElementById('edit-username').value = userData ? (userData.username || '') : '';
            document.getElementById('edit-email').value = userData ? (userData.email || '') : '';
            new bootstrap.Modal(document.getElementById('edit-profile-modal')).show();
        }
        function saveProfileChanges() {
            var newUsername = document.getElementById('edit-username').value.trim();
            var newEmail = document.getElementById('edit-email').value.trim();
            if (!newUsername || newUsername.length < 3) { showToast('Username must be at least 3 characters', 'error'); return; }
            var updates = { lastActive: Date.now() };
            if (newUsername !== userData.username) updates.username = newUsername;
            if (newEmail !== userData.email) updates.email = newEmail;
            db.ref('users/' + auth.currentUser.uid).update(updates)
                .then(function() {
                    showToast('✅ Profile updated successfully!', 'success');
                    bootstrap.Modal.getInstance(document.getElementById('edit-profile-modal')).hide();
                    updateProfileUI();
                })
                .catch(function(error) { showToast('Failed to update profile. Please try again.', 'error'); });
        }

        function openChangePassword() {
            document.getElementById('current-pass').value = '';
            document.getElementById('new-pass').value = '';
            document.getElementById('confirm-new-pass').value = '';
            new bootstrap.Modal(document.getElementById('change-password-modal')).show();
        }
        function updatePassword() {
            var currentPass = document.getElementById('current-pass').value;
            var newPass = document.getElementById('new-pass').value;
            var confirmPass = document.getElementById('confirm-new-pass').value;
            if (!currentPass || !newPass || !confirmPass) { showToast('Please fill all password fields', 'error'); return; }
            if (newPass !== confirmPass) { showToast('New passwords do not match', 'error'); return; }
            if (newPass.length < 6) { showToast('Password must be at least 6 characters', 'error'); return; }
            var user = auth.currentUser;
            var credential = firebase.auth.EmailAuthProvider.credential(user.email, currentPass);
            user.reauthenticateWithCredential(credential)
                .then(function() {
                    return user.updatePassword(newPass);
                })
                .then(function() {
                    showToast('✅ Password changed successfully!', 'success');
                    bootstrap.Modal.getInstance(document.getElementById('change-password-modal')).hide();
                })
                .catch(function(error) {
                    var msg = 'Failed to change password. ';
                    if (error.code === 'auth/wrong-password') msg += 'Current password is incorrect.';
                    else msg += error.message;
                    showToast(msg, 'error');
                });
        }

        function openSecuritySettings() { new bootstrap.Modal(document.getElementById('security-modal')).show(); }
        function saveSecuritySettings() { showToast('✅ Security settings saved!', 'success'); bootstrap.Modal.getInstance(document.getElementById('security-modal')).hide(); }
        function showAppInfo() { showConfirmModal('info', 'App Information', '<strong>VEGAS Investment v3.0.0</strong><br><br>© 2024 VEGAS<br>All rights reserved.', 'Close', null); }

        function confirmLogout() {
            showConfirmModal('warning', 'Confirm Logout', 'Are you sure you want to logout? You will need to sign in again to access your account.', 'Cancel', function() {
                auth.signOut().then(function() {
                    showToast('✅ Logged out successfully', 'success');
                    Object.values(timerIntervals).forEach(function(interval) { clearInterval(interval); }); 
                    timerIntervals = {};
                    navigate('home');
                });
            }, 'Logout');
        }

        // ========================================
        // AUTH FORM HANDLERS
        // ========================================
        document.getElementById('reg-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var username = document.getElementById('reg-user').value.trim();
            var email = document.getElementById('reg-email').value.trim();
            var pass = document.getElementById('reg-pass').value;
            var confirmPass = document.getElementById('reg-confirm').value;
            var inviteCode = document.getElementById('reg-invite').value.trim();
            if (username.length < 3) { showToast('Username must be at least 3 characters', 'error'); return; }
            if (pass !== confirmPass) { showToast('Passwords do not match', 'error'); return; }
            if (pass.length < 6) { showToast('Password must be at least 6 characters', 'error'); return; }
            auth.createUserWithEmailAndPassword(email, pass)
                .then(function(userCredential) {
                    var user = userCredential.user;
                    return db.ref('users/' + user.uid).set({
                        uid: user.uid, username: username, email: email, balance: 0, totalInvested: 0,
                        dailyIncome: 0, totalReturns: 0, referralEarnings: 0, totalReferrals: 0,
                        activeReferrals: 0, referredBy: inviteCode || 'none', claimBonus: false,
                        hasSeenWelcome: false, createdAt: Date.now(), lastActive: Date.now()
                    });
                })
                .then(function() {
                    if (inviteCode && inviteCode !== 'none') {
                        db.ref('users').orderByChild('username').equalTo(inviteCode).once('value').then(function(referrerSnap) {
                            referrerSnap.forEach(function(referrer) {
                                db.ref('users/' + referrer.key + '/totalReferrals').transaction(function(count) { return (count || 0) + 1; });
                            });
                        });
                    }
                    showToast('✅ Account created successfully! Welcome to VEGAS.', 'success');
                })
                .catch(function(error) {
                    var msg = 'Registration failed. ';
                    if (error.code === 'auth/email-already-in-use') msg += 'Email already registered.';
                    else if (error.code === 'auth/invalid-email') msg += 'Invalid email address.';
                    else if (error.code === 'auth/weak-password') msg += 'Password too weak.';
                    else msg += error.message;
                    showToast(msg, 'error');
                });
        });

        document.getElementById('login-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var email = document.getElementById('login-email').value.trim();
            var pass = document.getElementById('login-pass').value;
            auth.signInWithEmailAndPassword(email, pass)
                .then(function() {
                    showToast('✅ Welcome back!', 'success');
                })
                .catch(function(error) {
                    var msg = 'Login failed. ';
                    if (error.code === 'auth/user-not-found' || error.code === 'auth/wrong-password') msg += 'Invalid email or password.';
                    else msg += error.message;
                    showToast(msg, 'error');
                });
        });

        // ========================================
        // BONUS & CONFIRMATION MODAL
        // ========================================
        function claimWelcomeBonus() {
            var modal = bootstrap.Modal.getInstance(document.getElementById('welcome-modal'));
            if (modal) modal.hide();
            var uid = auth.currentUser.uid;
            db.ref('users/' + uid).update({ balance: (userData.balance || 0) + 600, claimBonus: true })
                .then(function() {
                    return db.ref('transactions').push().set({ uid: uid, type: 'bonus', amount: 600, status: 'completed', timestamp: Date.now(), description: 'Welcome bonus' });
                })
                .then(function() {
                    new bootstrap.Modal(document.getElementById('bonus-modal')).show();
                    updateBalanceUI();
                })
                .catch(function(error) { showToast('Failed to claim bonus. Please try again.', 'error'); });
        }

        function showConfirmModal(type, title, message, cancelText, onConfirm, confirmText) {
            confirmText = confirmText || 'Confirm';
            var modal = document.getElementById('confirm-modal');
            var icon = document.getElementById('confirm-icon');
            icon.className = 'confirm-icon bi';
            if (type === 'success') { icon.classList.add('bi-check-circle-fill'); icon.style.color = 'var(--success)'; }
            else if (type === 'warning') { icon.classList.add('bi-exclamation-triangle-fill'); icon.style.color = 'var(--warning)'; }
            else if (type === 'danger') { icon.classList.add('bi-x-circle-fill'); icon.style.color = 'var(--danger)'; }
            else { icon.classList.add('bi-info-circle-fill'); icon.style.color = 'var(--vegas-gold)'; }
            document.getElementById('confirm-title').textContent = title;
            document.getElementById('confirm-message').innerHTML = message;
            modal.querySelector('.confirm-btn.cancel').textContent = cancelText;
            document.getElementById('confirm-action-btn').textContent = confirmText;
            confirmCallback = onConfirm;
            modal.style.display = 'flex';
            modal.querySelector('.confirm-btn.cancel').onclick = closeConfirmModal;
        }
        function closeConfirmModal() { 
            document.getElementById('confirm-modal').style.display = 'none'; 
            confirmCallback = null; 
        }
        function executeConfirmAction() { 
            if (confirmCallback) confirmCallback(); 
            closeConfirmModal(); 
        }
        document.getElementById('confirm-modal').addEventListener('click', function(e) { 
            if (e.target.id === 'confirm-modal') closeConfirmModal(); 
        });

        // ========================================
        // NOTIFICATIONS
        // ========================================
        function renderNotifications() {
            var list = document.getElementById('notif-list');
            if (!list) return;
            var notifs = [
                { title: 'Welcome to VEGAS!', message: 'Your account is active. Claim your bonus and start investing today.', time: 'Just now', icon: 'bi-star-fill', type: 'info' },
                { title: 'New Plan Available', message: 'Check out our VIP (Rolls-Royce) plan with 250% total returns!', time: '2 hours ago', icon: 'bi-gem', type: 'info' },
                { title: 'Withdrawal Processed', message: 'Your withdrawal of ₦5,000 has been approved and sent to your bank.', time: '1 day ago', icon: 'bi-cash-stack', type: 'success' }
            ];
            list.innerHTML = notifs.map(function(n) { 
                return '<div class="faq-item"><h4><i class="bi ' + n.icon + ' text-gold"></i> ' + n.title + '</h4><p>' + n.message + '</p><small class="text-gray">' + n.time + '</small></div>'; 
            }).join('');
            var badge = document.getElementById('notif-badge');
            if (badge) { 
                var unread = notifs.filter(function(n) { return !n.read; }).length; 
                badge.textContent = unread; 
                badge.classList.toggle('hidden', unread === 0); 
            }
        }

        // Page visibility handling
        document.addEventListener('visibilitychange', function() {
            if (!document.hidden && userData) { 
                checkAndClaimEarnings(); 
                updateActivePlansUI(); 
            }
        });

        // Initialize app
        document.addEventListener('DOMContentLoaded', function() { 
            checkPWAInstallable(); 
        });
    </script>
</body>
</html>         