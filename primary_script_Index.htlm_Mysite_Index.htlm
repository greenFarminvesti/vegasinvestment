
                        <!DOCTYPE html>
                        <html lang="en">
                        <head>
                            <meta charset="UTF-8">
                            <meta name="viewport" content="width=device-width, initial-scale=1.0">
              <style>
                body {
                  background-color: white; /* Ensure the iframe has a white background */
                }

                
              </style>
                        </head>
                        <body>
                            <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#8B0000">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>VEGAS | Premium Investment</title>
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="application/json;base64,">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">
    
    <!-- Firebase SDKs -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <style>
        :root {
            /* VEGAS Casino Theme */
            --vegas-red: #8B0000;
            --vegas-red-dark: #660000;
            --vegas-red-light: #A52A2A;
            --vegas-gold: #D4AF37;
            --vegas-gold-light: #F4D06F;
            --vegas-black: #0a0a0a;
            --vegas-dark: #121212;
            --vegas-card: #1a1a1a;
            --vegas-card-hover: #222;
            --text-white: #ffffff;
            --text-gold: #D4AF37;
            --text-gray: #b0b0b0;
            --text-muted: #777;
            --gradient-vegas: linear-gradient(135deg, #8B0000 0%, #660000 30%, #D4AF37 70%, #F4D06F 100%);
            --gradient-gold: linear-gradient(135deg, #D4AF37 0%, #B89D2E 50%, #AA8B2C 100%);
            --shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.95);
            --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.7);
            --shadow-glow: 0 0 30px rgba(212, 175, 55, 0.35);
            --shadow-red: 0 0 25px rgba(139, 0, 0, 0.4);
            --success: #198754;
            --warning: #ffc107;
            --danger: #dc3545;
            --info: #0dcaf0;
            --purple: #9333ea;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Montserrat', sans-serif; -webkit-tap-highlight-color: transparent; }
        
        body { 
            background-color: var(--vegas-black); 
            color: var(--text-white); 
            overflow-x: hidden;
            padding-bottom: 85px;
            background-image: 
                radial-gradient(ellipse at 20% 15%, rgba(139, 0, 0, 0.15) 0%, transparent 45%),
                radial-gradient(ellipse at 80% 85%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(255, 215, 0, 0.03) 0%, transparent 70%),
                url("image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23D4AF37' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zm0-30V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            background-attachment: fixed;
        }
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: 
                repeating-linear-gradient(45deg, transparent, transparent 1px, rgba(212, 175, 55, 0.02) 1px, rgba(212, 175, 55, 0.02) 2px),
                repeating-linear-gradient(-45deg, transparent, transparent 1px, rgba(139, 0, 0, 0.02) 1px, rgba(139, 0, 0, 0.02) 2px);
            pointer-events: none;
            z-index: 0;
        }

        .hidden { display: none !important; }
        .text-gold { color: var(--text-gold) !important; }
        .text-red { color: var(--vegas-red-light) !important; }
        .bg-gold { background: var(--gradient-gold) !important; }
        .bg-vegas { background: var(--gradient-vegas) !important; }
        
        /* VEGAS Logo */
        .app-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
        }
        .logo-icon {
            width: 40px;
            height: 40px;
            background: var(--gradient-vegas);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-glow), var(--shadow-red);
            position: relative;
            overflow: hidden;
            border: 2px solid var(--vegas-gold);
        }
        .logo-icon::before {
            content: '';
            position: absolute;
            width: 150%;
            height: 150%;
            background: linear-gradient(45deg, transparent, rgba(255,255,255,0.4), transparent);
            transform: rotate(45deg) translateX(-100%);
            animation: shine 2.5s infinite;
        }
        @keyframes shine { 100% { transform: rotate(45deg) translateX(100%); } }
        .logo-icon i { 
            font-size: 20px; 
            color: #000; 
            position: relative; 
            z-index: 1;
            text-shadow: 0 1px 2px rgba(255,255,255,0.3);
        }
        .logo-text {
            font-family: 'Playfair Display', serif;
            font-weight: 900;
            font-size: 20px;
            letter-spacing: 3px;
            background: var(--gradient-vegas);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        /* Buttons */
        .btn-gold {
            background: var(--gradient-gold);
            border: none;
            color: #000;
            font-weight: 700;
            padding: 12px 28px;
            border-radius: 14px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 18px rgba(212, 175, 55, 0.4);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 14px;
            letter-spacing: 0.5px;
        }
        .btn-gold:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(212, 175, 55, 0.6);
            color: #000;
        }
        .btn-gold:active { transform: translateY(0); }
        .btn-outline-gold {
            border: 2px solid var(--vegas-gold);
            color: var(--vegas-gold);
            background: transparent;
            padding: 10px 22px;
            border-radius: 14px;
            font-weight: 600;
            transition: all 0.3s;
            font-size: 14px;
        }
        .btn-outline-gold:hover {
            background: var(--vegas-gold);
            color: #000;
            transform: translateY(-2px);
        }
        .btn-red {
            background: var(--vegas-red);
            border: none;
            color: white;
            font-weight: 700;
            padding: 12px 28px;
            border-radius: 14px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 18px rgba(139, 0, 0, 0.4);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-red:hover {
            background: var(--vegas-red-dark);
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(139, 0, 0, 0.6);
            color: white;
        }

        /* Auth Styles */
        .auth-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: 
                radial-gradient(ellipse at center, #1a0a0a 0%, #0a0000 70%),
                url('https://images.unsplash.com/photo-1596838132731-3301c3fd4317?q=80&w=1920');
            background-size: cover;
            background-position: center;
            padding: 20px;
            position: relative;
        }
        .auth-container::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle at 30% 20%, rgba(139,0,0,0.25) 0%, transparent 40%),
                        radial-gradient(circle at 70% 80%, rgba(212,175,55,0.15) 0%, transparent 45%);
            pointer-events: none;
        }
        .auth-card {
            background: var(--vegas-card);
            width: 100%;
            max-width: 420px;
            padding: 36px 32px;
            border-radius: 32px;
            border: 2px solid rgba(212, 175, 55, 0.4);
            box-shadow: var(--shadow), var(--shadow-glow);
            position: relative;
            z-index: 2;
        }
        .auth-card::before {
            content: '';
            position: absolute;
            top: -3px; left: -3px; right: -3px; bottom: -3px;
            background: var(--gradient-vegas);
            border-radius: 35px;
            z-index: -1;
            opacity: 0.25;
            filter: blur(12px);
        }
        .form-control {
            background: #1a1a1a;
            border: 1px solid #333;
            color: white;
            padding: 14px 18px;
            border-radius: 14px;
            margin: 10px 0;
            font-size: 14px;
            transition: all 0.3s;
        }
        .form-control:focus {
            background: #222;
            border-color: var(--vegas-gold);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.25);
            color: white;
        }
        .form-control::placeholder { color: var(--text-muted); }
        .form-label { color: var(--text-gray); font-size: 13px; margin-bottom: 6px; font-weight: 600; }

        /* Header */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 20px;
            background: var(--vegas-dark);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
            backdrop-filter: blur(12px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        }

        /* Summary Card - VEGAS Style */
        .summary-card {
            background: var(--gradient-vegas);
            margin: 18px;
            padding: 24px;
            border-radius: 26px;
            color: #000;
            box-shadow: var(--shadow-glow), var(--shadow-red);
            position: relative;
            overflow: hidden;
            border: 2px solid var(--vegas-gold);
        }
        .summary-card::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.25) 0%, transparent 70%);
            animation: pulse 4s infinite;
        }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.3; } 50% { transform: scale(1.15); opacity: 0.5; } }
        .summary-card h2 {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            font-weight: 900;
            position: relative;
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
            letter-spacing: -1px;
        }
        .summary-stats {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
            font-size: 12px;
            background: rgba(0,0,0,0.2);
            padding: 14px 18px;
            border-radius: 16px;
            position: relative;
            border: 1px solid rgba(255,255,255,0.15);
        }

        /* Quick Menu */
        .quick-menu {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            padding: 0 18px;
            margin: 20px 0;
        }
        .menu-item {
            background: var(--vegas-card);
            padding: 22px 12px;
            border-radius: 20px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.1);
            font-size: 11px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-card);
        }
        .menu-item::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 3px;
            background: var(--gradient-vegas);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        .menu-item:hover {
            border-color: var(--vegas-gold);
            transform: translateY(-5px);
            background: var(--vegas-card-hover);
            box-shadow: var(--shadow-card), 0 0 15px rgba(212,175,55,0.2);
        }
        .menu-item:hover::before { transform: scaleX(1); }
        .menu-item i {
            font-size: 28px;
            color: var(--vegas-gold);
            margin-bottom: 12px;
            display: block;
            transition: transform 0.3s;
        }
        .menu-item:hover i { transform: scale(1.15) rotate(5deg); }

        /* Info Boxes */
        .info-box {
            background: var(--vegas-card);
            margin: 14px 18px;
            padding: 18px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            border-left: 5px solid var(--vegas-gold);
            cursor: pointer;
            transition: all 0.3s;
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: var(--shadow-card);
        }
        .info-box:hover {
            background: var(--vegas-card-hover);
            transform: translateX(5px);
            border-left-color: var(--vegas-red-light);
            box-shadow: var(--shadow-card), 0 0 12px rgba(139,0,0,0.2);
        }
        .info-box i {
            font-size: 28px;
            color: var(--vegas-gold);
            margin-right: 18px;
            min-width: 34px;
            text-align: center;
        }
        .info-box.whatsapp {
            background: linear-gradient(135deg, #075E54, #128C7E);
            border-left-color: #25D366;
        }
        .info-box.whatsapp i { color: white; }
        .info-box.pwa {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-left-color: var(--vegas-gold);
        }

        /* Plan Cards */
        .plan-card {
            background: var(--vegas-card);
            margin: 16px 18px;
            border-radius: 22px;
            display: flex;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.12);
            cursor: pointer;
            transition: all 0.35s ease;
            position: relative;
            box-shadow: var(--shadow-card);
        }
        .plan-card:hover {
            border-color: var(--vegas-gold);
            transform: translateY(-6px);
            box-shadow: var(--shadow-card), 0 0 25px rgba(212,175,55,0.25);
        }
        .plan-card::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 4px;
            background: var(--gradient-vegas);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .plan-card:hover::after { opacity: 1; }
        .plan-img {
            width: 44%;
            background-size: cover;
            background-position: center;
            min-height: 140px;
            position: relative;
        }
        .plan-img::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, transparent 35%, rgba(0,0,0,0.75));
        }
        .plan-details {
            padding: 18px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .plan-badge {
            background: var(--gradient-vegas);
            color: #000;
            padding: 5px 14px;
            border-radius: 22px;
            font-size: 10px;
            font-weight: 800;
            display: inline-block;
            margin-bottom: 12px;
            letter-spacing: 1px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        }
        .plan-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 14px 0;
            font-size: 11px;
        }
        .plan-stat-item {
            background: rgba(255,255,255,0.1);
            padding: 10px 14px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.15);
        }

        /* Active Plan */
        .active-plan-card {
            background: linear-gradient(135deg, #1a0a0a, #2a1a1a);
            border: 2px solid var(--vegas-gold);
            border-radius: 20px;
            padding: 20px;
            margin: 14px 18px;
            box-shadow: var(--shadow-card), var(--shadow-glow);
            position: relative;
            overflow: hidden;
        }
        .active-plan-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 3px;
            background: var(--gradient-vegas);
        }
        .timer-display {
            font-family: 'Courier New', monospace;
            font-size: 24px;
            font-weight: 800;
            color: var(--vegas-gold);
            background: rgba(0,0,0,0.5);
            padding: 12px 20px;
            border-radius: 14px;
            display: inline-block;
            margin: 14px 0;
            letter-spacing: 4px;
            border: 1px solid var(--vegas-gold);
            box-shadow: 0 0 15px rgba(212,175,55,0.3);
        }
        .progress {
            height: 10px;
            background: rgba(255,255,255,0.15);
            border-radius: 5px;
            margin: 14px 0;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .progress-bar {
            background: var(--gradient-vegas);
            border-radius: 5px;
            transition: width 0.5s ease;
            box-shadow: 0 0 10px rgba(212,175,55,0.4);
        }

        /* Wallet & Transactions */
        .wallet-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            padding: 0 18px;
            margin: 18px 0;
        }
        .wallet-btn {
            background: var(--vegas-card);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 18px;
            padding: 20px 14px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            box-shadow: var(--shadow-card);
        }
        .wallet-btn:hover {
            border-color: var(--vegas-gold);
            background: var(--vegas-card-hover);
            transform: translateY(-4px);
            box-shadow: var(--shadow-card), 0 0 15px rgba(212,175,55,0.2);
        }
        .wallet-btn i {
            font-size: 30px;
            color: var(--vegas-gold);
        }
        .wallet-btn span {
            font-size: 13px;
            font-weight: 600;
        }
        
        .tx-section-title {
            padding: 0 18px;
            margin: 26px 0 14px;
            font-size: 19px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--vegas-gold);
        }
        
        .tx-item {
            background: var(--vegas-card);
            padding: 18px;
            border-radius: 16px;
            margin: 0 18px 14px;
            border-left: 4px solid var(--vegas-gold);
            border: 1px solid rgba(255,255,255,0.12);
            transition: all 0.25s;
            box-shadow: var(--shadow-card);
        }
        .tx-item:hover {
            border-left-color: var(--vegas-red-light);
            background: var(--vegas-card-hover);
            transform: translateX(3px);
        }
        .tx-item.deposit { border-left-color: var(--success); }
        .tx-item.withdraw { border-left-color: var(--warning); }
        .tx-item.investment { border-left-color: var(--vegas-gold); }
        .tx-item.earnings { border-left-color: var(--info); }
        .tx-item.referral { border-left-color: var(--purple); }
        
        .tx-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-size: 14px;
            font-weight: 600;
        }
        .tx-amount {
            font-weight: 800;
            font-size: 20px;
            font-family: monospace;
            letter-spacing: -0.5px;
        }
        .tx-amount.positive { color: var(--success); }
        .tx-amount.negative { color: var(--danger); }
        .tx-status {
            font-size: 11px;
            padding: 5px 14px;
            border-radius: 22px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .status-pending {
            background: rgba(255,193,7,0.2);
            color: var(--warning);
            border: 1px solid rgba(255,193,7,0.4);
        }
        .status-approved {
            background: rgba(25,135,84,0.2);
            color: var(--success);
            border: 1px solid rgba(25,135,84,0.4);
        }
        .status-declined {
            background: rgba(220,53,69,0.2);
            color: var(--danger);
            border: 1px solid rgba(220,53,69,0.4);
        }

        /* Deposit/Withdraw Pages */
        .deposit-page, .bank-details-page, .withdraw-page {
            padding: 22px 18px;
        }
        .page-header {
            text-align: center;
            margin-bottom: 26px;
            padding-bottom: 22px;
            border-bottom: 1px solid rgba(255,255,255,0.12);
        }
        .page-header i {
            font-size: 46px;
            color: var(--vegas-gold);
            margin-bottom: 14px;
            display: block;
            text-shadow: 0 0 15px rgba(212,175,55,0.4);
        }
        .page-header h4 {
            font-family: 'Playfair Display', serif;
            font-weight: 800;
            font-size: 22px;
            margin-bottom: 8px;
            letter-spacing: 1px;
        }
        .page-header p {
            color: var(--text-gray);
            font-size: 14px;
        }
        
        .amount-selector {
            background: var(--vegas-card);
            border-radius: 22px;
            padding: 26px;
            margin-bottom: 26px;
            border: 1px solid rgba(255,255,255,0.15);
            box-shadow: var(--shadow-card);
        }
        .amount-input-group {
            position: relative;
            margin: 18px 0;
        }
        .amount-input-group::before {
            content: '₦';
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--vegas-gold);
            font-weight: 700;
            font-size: 20px;
            z-index: 2;
        }
        .amount-input {
            padding-left: 36px !important;
            font-size: 26px !important;
            font-weight: 800 !important;
            font-family: monospace !important;
        }
        .quick-amounts {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin: 18px 0;
        }
        .quick-amount-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            padding: 12px;
            color: var(--text-gray);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
        }
        .quick-amount-btn:hover, .quick-amount-btn.active {
            background: var(--gradient-vegas);
            color: #000;
            border-color: var(--vegas-gold);
            transform: scale(1.05);
            box-shadow: 0 0 12px rgba(212,175,55,0.3);
        }
        
        .bank-details-card {
            background: var(--vegas-card);
            border-radius: 22px;
            padding: 26px;
            margin-bottom: 26px;
            border: 2px solid var(--vegas-gold);
            box-shadow: var(--shadow-card), var(--shadow-glow);
            animation: slideUp 0.4s ease;
        }
        @keyframes slideUp { from { opacity: 0; transform: translateY(25px); } to { opacity: 1; transform: translateY(0); } }
        .bank-detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid rgba(255,255,255,0.12);
        }
        .bank-detail-row:last-child { border-bottom: none; }
        .bank-detail-label {
            color: var(--text-gray);
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
        }
        .bank-detail-label i {
            color: var(--vegas-gold);
            font-size: 18px;
        }
        .bank-detail-value {
            font-weight: 800;
            color: var(--vegas-gold);
            font-family: monospace;
            font-size: 17px;
            letter-spacing: 0.5px;
        }
        .copy-btn {
            background: rgba(212, 175, 55, 0.2);
            color: var(--vegas-gold);
            border: 1px solid var(--vegas-gold);
            padding: 7px 16px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 600;
            margin-left: 12px;
            transition: all 0.25s;
        }
        .copy-btn:hover {
            background: var(--vegas-gold);
            color: #000;
            transform: scale(1.05);
        }
        
        .sender-form {
            background: var(--vegas-card);
            border-radius: 22px;
            padding: 26px;
            border: 1px solid rgba(255,255,255,0.15);
            box-shadow: var(--shadow-card);
        }
        
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--text-gray);
            font-size: 14px;
            padding: 10px 18px;
            margin-bottom: 18px;
            cursor: pointer;
            transition: all 0.25s;
            border-radius: 12px;
        }
        .back-btn:hover {
            color: var(--vegas-gold);
            background: rgba(212,175,55,0.1);
        }
        
        /* Service Page */
        .service-hero {
            text-align: center;
            padding: 26px 18px 18px;
            margin-bottom: 18px;
        }
        .service-hero-icon {
            width: 85px;
            height: 85px;
            background: var(--gradient-vegas);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
            box-shadow: var(--shadow-glow), var(--shadow-red);
            animation: float 3.5s ease-in-out infinite;
            border: 3px solid var(--vegas-gold);
        }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
        .service-hero-icon i {
            font-size: 38px;
            color: #000;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }
        .service-hero h4 {
            font-family: 'Playfair Display', serif;
            font-weight: 800;
            font-size: 22px;
            margin-bottom: 10px;
            letter-spacing: 1px;
        }
        .service-hero p {
            color: var(--text-gray);
            font-size: 14px;
        }

        /* Profile */
        .profile-header {
            text-align: center;
            margin: 18px;
            padding: 26px;
            background: var(--vegas-card);
            border-radius: 24px;
            border: 2px solid rgba(212,175,55,0.4);
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-card), var(--shadow-glow);
        }
        .profile-header::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(212,175,55,0.12) 0%, transparent 70%);
            pointer-events: none;
        }
        .profile-avatar {
            width: 90px;
            height: 90px;
            background: var(--gradient-vegas);
            border-radius: 50%;
            margin: 0 auto 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 4px solid var(--vegas-gold);
            box-shadow: var(--shadow-glow);
            position: relative;
        }
        .profile-avatar i {
            font-size: 38px;
            color: #000;
            text-shadow: 0 2px 4px rgba(255,255,255,0.3);
        }
        .profile-name {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 800;
            margin-bottom: 6px;
            letter-spacing: 1px;
        }
        .profile-email {
            color: var(--text-gray);
            font-size: 14px;
            margin-bottom: 14px;
        }
        .profile-badge {
            background: var(--gradient-vegas);
            color: #000;
            padding: 5px 16px;
            border-radius: 22px;
            font-size: 11px;
            font-weight: 700;
            display: inline-block;
            letter-spacing: 1px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        }
        
        .profile-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
            margin: 22px 18px;
        }
        .profile-stat {
            background: var(--vegas-card);
            padding: 18px 12px;
            border-radius: 18px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.15);
            transition: all 0.25s;
            box-shadow: var(--shadow-card);
        }
        .profile-stat:hover {
            border-color: var(--vegas-gold);
            transform: translateY(-3px);
            box-shadow: var(--shadow-card), 0 0 12px rgba(212,175,55,0.2);
        }
        .profile-stat-value {
            font-weight: 800;
            color: var(--vegas-gold);
            font-size: 20px;
            font-family: monospace;
        }
        .profile-stat-label {
            font-size: 11px;
            color: var(--text-gray);
            margin-top: 6px;
            font-weight: 500;
        }

        .referral-card {
            background: linear-gradient(135deg, #1a0a0a, #2a1a1a);
            border: 2px solid var(--vegas-gold);
            border-radius: 20px;
            padding: 22px;
            margin: 18px;
            text-align: center;
            box-shadow: var(--shadow-card), var(--shadow-glow);
        }
        .referral-title {
            color: var(--vegas-gold);
            font-weight: 700;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 16px;
        }
        .referral-desc {
            font-size: 14px;
            color: var(--text-gray);
            margin-bottom: 18px;
            line-height: 1.6;
        }
        .referral-code {
            background: rgba(0,0,0,0.5);
            color: var(--vegas-gold);
            padding: 14px 22px;
            border-radius: 14px;
            font-family: monospace;
            font-weight: 800;
            font-size: 20px;
            margin: 14px 0;
            display: inline-block;
            letter-spacing: 5px;
            border: 2px solid var(--vegas-gold);
            width: 100%;
            max-width: 300px;
            box-shadow: 0 0 15px rgba(212,175,55,0.3);
        }
        .commission-info {
            background: rgba(255,255,255,0.1);
            padding: 16px;
            border-radius: 14px;
            margin: 18px 0;
            font-size: 14px;
            text-align: left;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .commission-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }
        .commission-row:last-child { border-bottom: none; }
        .commission-value {
            font-weight: 700;
            color: var(--vegas-gold);
        }

        .profile-actions {
            margin: 22px 18px;
        }
        .profile-action-btn {
            background: var(--vegas-card);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 16px;
            padding: 18px;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 16px;
            cursor: pointer;
            transition: all 0.3s;
            width: 100%;
            text-align: left;
            box-shadow: var(--shadow-card);
        }
        .profile-action-btn:hover {
            border-color: var(--vegas-gold);
            background: var(--vegas-card-hover);
            transform: translateX(5px);
            box-shadow: var(--shadow-card), 0 0 12px rgba(212,175,55,0.2);
        }
        .profile-action-btn i {
            font-size: 24px;
            color: var(--vegas-gold);
            width: 26px;
            text-align: center;
        }
        .profile-action-btn span {
            font-size: 15px;
            font-weight: 600;
            flex: 1;
        }
        .profile-action-btn .bi-chevron-right {
            color: var(--text-muted);
            font-size: 20px;
        }

        /* Service FAQ */
        .section-title {
            color: var(--vegas-gold);
            margin: 22px 18px 18px;
            font-size: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            font-family: 'Playfair Display', serif;
        }
        .section-title i {
            font-size: 22px;
            text-shadow: 0 0 10px rgba(212,175,55,0.4);
        }
        .faq-item {
            background: var(--vegas-card);
            padding: 20px;
            border-radius: 16px;
            margin: 0 18px 16px;
            border-left: 4px solid var(--vegas-gold);
            border: 1px solid rgba(255,255,255,0.15);
            transition: all 0.25s;
            box-shadow: var(--shadow-card);
        }
        .faq-item:hover {
            border-left-color: var(--vegas-red-light);
            background: var(--vegas-card-hover);
            transform: translateX(3px);
        }
        .faq-item h4 {
            color: var(--vegas-gold);
            margin-bottom: 12px;
            font-size: 17px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .faq-item p {
            font-size: 14px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        /* Utility */
        .warn-text {
            font-size: 14px;
            color: #ffbcbc;
            background: rgba(220,53,69,0.15);
            padding: 16px 18px;
            border-radius: 16px;
            margin: 18px;
            border-left: 4px solid var(--danger);
            border: 1px solid rgba(220,53,69,0.3);
            line-height: 1.6;
            box-shadow: 0 0 12px rgba(220,53,69,0.2);
        }
        .success-text {
            font-size: 14px;
            color: #a5d6a7;
            background: rgba(25,135,84,0.15);
            padding: 16px 18px;
            border-radius: 16px;
            margin: 18px;
            border-left: 4px solid var(--success);
            border: 1px solid rgba(25,135,84,0.3);
            line-height: 1.6;
            box-shadow: 0 0 12px rgba(25,135,84,0.2);
        }
        .info-text {
            font-size: 14px;
            color: #93c5fd;
            background: rgba(14,165,233,0.15);
            padding: 16px 18px;
            border-radius: 16px;
            margin: 18px;
            border-left: 4px solid var(--info);
            border: 1px solid rgba(14,165,233,0.3);
            line-height: 1.6;
            box-shadow: 0 0 12px rgba(14,165,233,0.2);
        }
        .empty-state {
            text-align: center;
            padding: 45px 22px;
            color: var(--text-gray);
        }
        .empty-state i {
            font-size: 52px;
            opacity: 0.35;
            margin-bottom: 18px;
            display: block;
        }

        /* Bottom Nav */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            width: 100%;
            background: var(--vegas-dark);
            display: flex;
            justify-content: space-around;
            padding: 12px 0;
            border-top: 1px solid rgba(212,175,55,0.3);
            z-index: 1000;
            padding-bottom: env(safe-area-inset-bottom);
            backdrop-filter: blur(12px);
            box-shadow: 0 -4px 20px rgba(0,0,0,0.4);
        }
        .nav-link {
            text-align: center;
            color: var(--text-gray);
            font-size: 10px;
            cursor: pointer;
            padding: 8px 0;
            transition: all 0.3s;
            position: relative;
            min-width: 62px;
            font-weight: 500;
        }
        .nav-link.active {
            color: var(--vegas-gold);
        }
        .nav-link.active::after {
            content: '';
            position: absolute;
            bottom: -3px;
            left: 50%;
            transform: translateX(-50%);
            width: 28px;
            height: 4px;
            background: var(--gradient-vegas);
            border-radius: 2px;
            box-shadow: 0 0 8px rgba(212,175,55,0.5);
        }
        .nav-link i {
            display: block;
            font-size: 22px;
            margin-bottom: 5px;
            transition: transform 0.25s;
        }
        .nav-link:hover i {
            transform: scale(1.15);
        }
        .nav-link:hover {
            color: var(--vegas-gold-light);
        }

        /* Modals */
        .modal-content {
            background: var(--vegas-card);
            padding: 30px;
            border-radius: 26px;
            text-align: center;
            border: 2px solid var(--vegas-gold);
            max-width: 440px;
            box-shadow: var(--shadow), var(--shadow-glow);
            margin: 22px;
        }
        .plan-detail-img {
            width: 100%;
            height: 200px;
            border-radius: 18px;
            background-size: cover;
            background-position: center;
            margin: 20px 0;
            border: 3px solid var(--vegas-gold);
            box-shadow: 0 4px 25px rgba(0,0,0,0.5);
            position: relative;
        }
        .plan-detail-img::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.65), transparent);
            border-radius: 18px;
        }
        .plan-detail-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin: 20px 0;
        }
        .stat-box {
            background: rgba(255,255,255,0.1);
            padding: 16px;
            border-radius: 14px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .stat-box-value {
            font-weight: 800;
            color: var(--vegas-gold);
            font-size: 22px;
            font-family: monospace;
        }
        .stat-box-label {
            font-size: 12px;
            color: var(--text-gray);
            margin-top: 6px;
            font-weight: 500;
        }

        /* Profile Modals */
        .modal-profile {
            background: var(--vegas-card);
            border-radius: 22px;
            padding: 26px;
            border: 2px solid rgba(212,175,55,0.4);
            max-width: 420px;
            margin: 22px;
            box-shadow: var(--shadow-card), var(--shadow-glow);
        }
        .modal-profile-title {
            color: var(--vegas-gold);
            font-weight: 800;
            font-size: 22px;
            margin-bottom: 22px;
            text-align: center;
            font-family: 'Playfair Display', serif;
        }
        .modal-profile-input {
            width: 100%;
            padding: 16px;
            margin: 12px 0;
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 14px;
            color: white;
            font-size: 15px;
        }
        .modal-profile-input:focus {
            border-color: var(--vegas-gold);
            outline: none;
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.25);
        }

        /* Confirm Modal */
        .confirm-modal {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.9);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            padding: 22px;
        }
        .confirm-content {
            background: var(--vegas-card);
            border-radius: 22px;
            padding: 30px;
            max-width: 400px;
            width: 100%;
            border: 2px solid var(--vegas-gold);
            box-shadow: var(--shadow), var(--shadow-glow);
            text-align: center;
        }
        .confirm-icon {
            font-size: 52px;
            margin-bottom: 18px;
            display: block;
        }
        .confirm-title {
            font-weight: 800;
            font-size: 22px;
            margin-bottom: 14px;
            font-family: 'Playfair Display', serif;
        }
        .confirm-message {
            color: var(--text-gray);
            font-size: 15px;
            margin-bottom: 26px;
            line-height: 1.6;
        }
        .confirm-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }
        .confirm-btn {
            padding: 14px;
            border-radius: 14px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            font-size: 15px;
            transition: all 0.25s;
        }
        .confirm-btn.cancel {
            background: rgba(255,255,255,0.15);
            color: white;
        }
        .confirm-btn.ok-approve {
            background: var(--gradient-vegas);
            color: #000;
        }
        .confirm-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        /* Toast */
        .toast-container {
            position: fixed;
            bottom: 95px;
            right: 18px;
            z-index: 1100;
            max-width: 340px;
        }
        .custom-toast {
            background: var(--vegas-card);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 16px;
            padding: 16px 20px;
            margin-bottom: 12px;
            box-shadow: var(--shadow-card), 0 0 15px rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            gap: 14px;
            animation: slideIn 0.35s ease;
            border-left: 4px solid var(--vegas-gold);
        }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .toast-success { border-left-color: var(--success); }
        .toast-error { border-left-color: var(--danger); }
        .toast-icon {
            font-size: 22px;
            min-width: 26px;
        }
        .toast-close {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 20px;
            cursor: pointer;
            padding: 0;
            width: 26px;
            height: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Loader */
        #loader {
            position: fixed;
            width:100%;
            height:100%;
            background:var(--vegas-black);
            display:flex;
            justify-content:center;
            align-items:center;
            z-index:9999;
            flex-direction: column;
            gap: 24px;
        }
        .spinner {
            width: 60px;
            height: 60px;
            border: 5px solid rgba(212, 175, 55, 0.25);
            border-top: 5px solid var(--vegas-gold);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            box-shadow: var(--shadow-glow);
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .loader-text {
            color: var(--vegas-gold);
            font-weight: 800;
            letter-spacing: 4px;
            font-size: 16px;
            font-family: 'Playfair Display', serif;
            text-shadow: 0 0 10px rgba(212,175,55,0.5);
        }
    </style>
</head>
<body>

    <!-- Loader -->
    <div id="loader">
        <div class="spinner"></div>
        <div class="loader-text">VEGAS</div>
    </div>

    <!-- AUTH SECTION -->
    <div id="auth-section" class="auth-container">
        <!-- Register -->
        <div id="register-page" class="auth-card">
            <div class="text-center mb-4">
                <div class="app-logo mx-auto mb-3">
                    <div class="logo-icon"><i class="bi bi-dice-6"></i></div>
                    <span class="logo-text">VEGAS</span>
                </div>
                <h3 class="text-gold mt-2" style="font-size:24px;font-family:'Playfair Display',serif">Create Account</h3>
                <p class="text-gray small">Join VEGAS Premium Investment</p>
            </div>
            <form id="reg-form">
                <label class="form-label">Username</label>
                <input type="text" id="reg-user" class="form-control" placeholder="Choose a username" required minlength="3">
                <label class="form-label">Email Address</label>
                <input type="email" id="reg-email" class="form-control" placeholder="your@email.com" required>
                <label class="form-label">Password</label>
                <input type="password" id="reg-pass" class="form-control" placeholder="••••••••" required minlength="6">
                <label class="form-label">Confirm Password</label>
                <input type="password" id="reg-confirm" class="form-control" placeholder="••••••••" required>
                <label class="form-label">Invite Code (Optional)</label>
                <input type="text" id="reg-invite" class="form-control" placeholder="Enter referrer's code">
                <button type="submit" class="btn-gold w-100 mt-4">Create Account</button>
            </form>
            <p class="text-center mt-4 small">Already have an account? <span class="text-gold fw-bold" style="cursor:pointer" onclick="toggleAuth('login')">Login Here</span></p>
        </div>

        <!-- Login -->
        <div id="login-page" class="auth-card hidden">
            <div class="text-center mb-4">
                <div class="app-logo mx-auto mb-3">
                    <div class="logo-icon"><i class="bi bi-dice-6"></i></div>
                    <span class="logo-text">VEGAS</span>
                </div>
                <h3 class="text-gold mt-2" style="font-size:24px;font-family:'Playfair Display',serif">Welcome Back</h3>
                <p class="text-gray small">Sign in to your VEGAS account</p>
            </div>
            <form id="login-form">
                <label class="form-label">Email Address</label>
                <input type="email" id="login-email" class="form-control" placeholder="your@email.com" required>
                <label class="form-label">Password</label>
                <input type="password" id="login-pass" class="form-control" placeholder="••••••••" required>
                <button type="submit" class="btn-gold w-100 mt-4">Sign In</button>
            </form>
            <p class="text-center mt-4 small">New to VEGAS? <span class="text-gold fw-bold" style="cursor:pointer" onclick="toggleAuth('reg')">Register Now</span></p>
        </div>
    </div>

    <!-- MAIN APP -->
    <main id="app-container" class="hidden">
        <header>
            <div class="app-logo" onclick="navigate('home')">
                <div class="logo-icon"><i class="bi bi-dice-6"></i></div>
                <span class="logo-text">VEGAS</span>
            </div>
